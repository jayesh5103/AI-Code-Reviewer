# Groq API Key (required for live AI reviews)
# Get a key from: https://console.groq.com/
GROQ_API_KEY=gsk_your_groq_api_key_here

# Usage alert threshold (optional, e.g., 0.80 for 80% of daily quota)
QUOTA_ALERT_THRESHOLD=0.80

# Discord Webhook URL for quota alerts (optional)
# Example: https://discord.com/api/webhooks/...
ALERT_WEBHOOK_URL=https://discord.com/api/webhooks/your_webhook_url_here
